# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
# Optional local override for the app port. Railway injects PORT automatically.
PORT=8000
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars

# ── CORS (comma-separated, no spaces) ────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ─────────────────────────────────────────────────────────────────
# Pooled / async connection used by the app at runtime (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/biosi_db?ssl=require

# Direct connection used by Alembic migrations (psycopg driver)
DATABASE_URL_DIRECT=postgresql+psycopg://user:password@direct-host:5432/biosi_db?sslmode=require

# ── OpenRouter (Milestone 3+) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL_PRIMARY=anthropic/claude-3.7-sonnet
OPENROUTER_MODEL_FALLBACK=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT_SECONDS=45

# ── External sources ──────────────────────────────────────────────────────────
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2/studies

# ── n8n Webhooks (Milestone 4+) ───────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=
